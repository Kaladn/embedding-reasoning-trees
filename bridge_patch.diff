    def get_616(self, word: str, topk: Optional[int] = None,
                include_suppressed: bool = False) -> Dict[str, Any]:
        """Return 6-1-6 positional view for *word*.

        Args:
            word: anchor token to look up
            topk: max neighbors per position (default: self.top_k)
            include_suppressed: if False (default), neighbors whose
                ``category`` is in SUPPRESSED_VIEW_CLASSES are hidden.
                Set True for forensic / debug / full-graph mode.

        Response fields:
            total_co_occurrence_weight: sum of ALL neighbor counts across
                all 12 positions — raw, unfiltered, from the stored map.
                This is NOT an occurrence count — it is the aggregate
                strength of this anchor's connections. ALWAYS raw truth.
            visible_weight: sum after suppression + trimming. Only present
                when view_filtered is True. Do NOT treat as authoritative.
            view_filtered: whether suppression was applied
            suppressed_count: how many neighbor entries were hidden
        """
        empty = {
            "word": word, "before": {}, "after": {},
            "total_co_occurrence_weight": 0,
            "view_filtered": not include_suppressed,
            "suppressed_count": 0,
        }
        if not self.last_map_result:
            return empty
        norm = self.normalise_token(word)
        payload = self.last_map_result.get("items", {}).get(norm)
        if not payload:
            return empty

        limit = topk or self.top_k

        def trim(buckets: Dict[str, List[Dict[str, Any]]]):
            """Filter suppressed categories FIRST, then apply limit."""
            output: Dict[str, List[List[Any]]] = {}
            suppressed = 0
            for distance, items in buckets.items():
                if include_suppressed:
                    visible = items
                else:
                    visible = [
                        item for item in items
                        if item.get("category") not in SUPPRESSED_VIEW_CLASSES
                    ]
                    suppressed += len(items) - len(visible)
                output[distance] = [
                    [item["token"], item["count"]]
                    for item in visible[:limit]
                ]
            return output, suppressed

        # ── Raw total from UNFILTERED stored payload — this is truth ──
        raw_before = payload.get("before", {})
        raw_after = payload.get("after", {})
        raw_weight = 0
        for buckets in raw_before.values():
            raw_weight += sum(item["count"] for item in buckets)
        for buckets in raw_after.values():
            raw_weight += sum(item["count"] for item in buckets)

        # ── Filtered view ──
        before, sup_before = trim(raw_before)
        after, sup_after = trim(raw_after)
        total_suppressed = sup_before + sup_after

        # Visible weight — sum from filtered+trimmed lists only.
        # Present for UI convenience, but NOT authoritative.
        visible_weight = sum(count for buckets in before.values() for _, count in buckets)
        visible_weight += sum(count for buckets in after.values() for _, count in buckets)

        result = {
            "word": payload.get("lexicon_word", word),
            "symbol": payload.get("symbol"),
            "before": before,
            "after": after,
            "total_co_occurrence_weight": int(raw_weight),
            "view_filtered": not include_suppressed,
            "suppressed_count": total_suppressed,
        }
        if not include_suppressed:
            result["visible_weight"] = int(visible_weight)
        return result

--- NOTES ---
- total_windows renamed to total_co_occurrence_weight (honest naming)
- RAW TOTAL IS ALWAYS RAW — computed from unfiltered stored payload, never
  from the filtered view. This is the truth field. It never changes based
  on view settings. Comparing filtered vs unfiltered runs will show the
  same total_co_occurrence_weight. That's the point.
- visible_weight is a convenience field — only present when filtering is
  active. Explicitly secondary. Do NOT use for ranking or comparison.
- Filter applied BEFORE limit — always get full useful lists
- include_suppressed=False default — function words hidden unless requested
- SUPPRESSED_VIEW_CLASSES at module scope — testable, reusable, no scatter
- Response carries view_filtered + suppressed_count for UI awareness
- Old maps without "category" field: item.get("category") returns None,
  None is not in SUPPRESSED_VIEW_CLASSES, so nothing gets suppressed.
  Fully backward compatible. Old maps are "legacy noisy" — accept it,
  don't silently pretend the views are equivalent.


